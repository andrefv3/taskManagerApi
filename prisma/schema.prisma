generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String          @id @default(uuid())
  email              String          @unique
  // 1. Opcional para soportar usuarios de Google
  password           String?   
  name               String
  lastName           String?         // 2. Opcional (Google a veces solo da 'name')
  profilePicture     String?         
  
  // 3. Campos específicos para OAuth
  googleId           String?         @unique // Para vincular la cuenta de forma única
  provider           AuthProvider    @default(LOCAL) // "local" or "google"
  
  tasks              Task[]
  
  // 4. Gestión de estado
  isVerified         Boolean         @default(false) 
  verificationCode   String?                 
  codeExpires        DateTime?             
  
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([email])
  @@index([googleId]) 
}

model Task {
  id          String     @id @default(uuid())
  title       String     @db.VarChar(255)
  description String?    @db.Text
  status      TaskStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)
  impact        Int        @default(1) // Scale 1-5 (Business Metric)
  effort        Int        @default(1) // Scale 1-5 (Technical Metric)
  priorityScore Float      @default(0) // The "Brain": calculated as (impact * 2) / effort
  
  // Relation with user (Task owner)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Critical indices for performance in production (Big Tech Standard)
  @@index([userId])            // To load user dashboard quickly
  @@index([status, priority])   // To filter combined in the UI
  @@index([priorityScore(sort: Desc)]) // To quickly find high-priority tasks
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}